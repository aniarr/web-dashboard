# Database (MongoDB)
DATABASE_URL=mongodb://127.0.0.1:27017/docgen

# Authentication & Session
# (Next-auth usually needs a secret, but our manual session uses cookies)

# Branding & Assets (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payments (Razorpay)
# Get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=placeholder_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder

# AI Content Generation (Optional)
# Get key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Server Configuration
PORT=3000
NODE_ENV=development

# Email Service (Resend)
# Get key from https://resend.com
RESEND_API_KEY=your_resend_api_key
